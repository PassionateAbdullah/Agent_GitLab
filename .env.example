# ─── GitLab ──────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx   # Personal Access Token, scopes: api, read_repository, write_repository

# Optional: restrict scan to a single group (id or full path). Blank = every project the token can see.
GITLAB_GROUP=

# Optional: dry-run — analyze and generate, but do NOT commit. Set to 1 to enable.
DRY_RUN=0


# ─── LLM ─────────────────────────────────────────────────────────────
# Pick ONE of the three providers below. Uncomment that block's three
# lines, fill in the API key, and the agent will use it.
#
# If LLM_MODEL is left blank, a sensible default for the provider is used.

# ── Option 1: Anthropic (Claude) ──
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
LLM_MODEL=claude-opus-4-7

# ── Option 2: OpenAI (GPT) ──
#LLM_PROVIDER=openai
#LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
#LLM_MODEL=gpt-4o-mini

# ── Option 3: Google Gemini ──
#LLM_PROVIDER=gemini
#LLM_API_KEY=xxxxxxxxxxxxxxxx
#LLM_MODEL=gemini-2.5-flash
